# =============================================================================
# vonage-ha-bridge — environment configuration
# Copy this file to .env and fill in your values.
#
# Only four variables are strictly required to run the service:
#   VONAGE_API_KEY, VONAGE_API_SECRET, VONAGE_FROM_NUMBER, INTERNAL_API_TOKEN
#
# All other variables unlock optional features — see the comments below.
# =============================================================================

# -----------------------------------------------------------------------------
# Server (optional — sensible defaults provided)
# -----------------------------------------------------------------------------

# Port to listen on (default: 3000)
PORT=3000

# Log level: debug | info | warning | error (default: info)
LOG_LEVEL=info

# Timeout for outbound Vonage API requests, in seconds (default: 10)
OUTBOUND_TIMEOUT_S=10

# -----------------------------------------------------------------------------
# Internal API — REQUIRED
# -----------------------------------------------------------------------------

# Secret token required in the x-api-token header for all /api/* requests.
# Use a strong random value, e.g.: openssl rand -hex 32
INTERNAL_API_TOKEN=

# -----------------------------------------------------------------------------
# Vonage credentials — REQUIRED
# -----------------------------------------------------------------------------

# Vonage API key and secret (from dashboard.vonage.com)
VONAGE_API_KEY=
VONAGE_API_SECRET=

# Your Vonage virtual number — digits only, with country code, no + prefix
# e.g. 46701234567
VONAGE_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Home Assistant — optional
#
# Required for:
#   • Inbound SMS → HA Assist → SMS reply
#   • Forwarding call events to an HA webhook
#   • Forwarding SMS delivery receipts to an HA webhook
#
# Both variables must be set together or left unset.
# -----------------------------------------------------------------------------

# Base URL of your Home Assistant instance — no trailing slash
HA_BASE_URL=http://homeassistant.local:8123

# Long-lived access token (generate in your HA profile page)
HA_LONG_LIVED_TOKEN=

# Webhook ID for inbound call events (must match your HA automation trigger)
# Default: vonage_call_event
HA_CALL_EVENT_WEBHOOK_ID=vonage_call_event

# Webhook ID for SMS delivery receipts (must match your HA automation trigger)
# Default: vonage_sms_dlr
HA_SMS_DLR_WEBHOOK_ID=vonage_sms_dlr

# Assist agent ID to use for SMS conversations (leave empty to use the default)
HA_ASSIST_AGENT_ID=

# Language code passed to HA Assist (default: en)
HA_LANGUAGE=en

# Timeout for HA Assist requests, in seconds (default: 30)
ASSIST_TIMEOUT_S=30

# -----------------------------------------------------------------------------
# Voice — optional
#
# Required for:
#   • Outbound TTS calls via POST /api/call
#   • Handling inbound calls (answer URL / call forwarding)
#
# Both VONAGE_APPLICATION_ID and VONAGE_PRIVATE_KEY_PATH must be set together
# or left unset. BASE_URL is additionally required for outbound calls.
# -----------------------------------------------------------------------------

# Public base URL of this service — no trailing slash.
# Must be reachable by Vonage (use a reverse proxy or ngrok in development).
# Required for outbound calls and as the event URL in call NCCOs.
BASE_URL=https://bridge.example.com

# Vonage application ID (from the Applications section of the dashboard)
VONAGE_APPLICATION_ID=

# Path to the private key file downloaded when creating your Vonage application
VONAGE_PRIVATE_KEY_PATH=/run/secrets/private.key

# Default TTS language for outbound calls (default: en-US)
DEFAULT_VOICE_LANGUAGE=en-US

# Default voice style index (default: 0 — varies by voice)
DEFAULT_VOICE_STYLE=0

# -----------------------------------------------------------------------------
# Call forwarding — optional
#
# Set at least one to forward inbound calls to a destination.
# FORWARD_SIP_URI takes priority over FORWARD_PHONE_NUMBER if both are set.
# Requires voice credentials above to be configured.
# -----------------------------------------------------------------------------

# SIP URI to forward inbound calls to (must start with sip:)
FORWARD_SIP_URI=

# Phone number to forward inbound calls to — digits only, with country code
FORWARD_PHONE_NUMBER=

# -----------------------------------------------------------------------------
# SMS options — optional
# -----------------------------------------------------------------------------

# Comma-separated allowlist of phone numbers permitted to send SMS commands.
# Leave empty to accept SMS from any sender.
# e.g. 46701234567,46709876543
ALLOWED_SMS_SENDERS=

# Maximum SMS message length (default: 1600)
SMS_MAX_LENGTH=1600

# -----------------------------------------------------------------------------
# Vonage SMS signature validation — optional but recommended
# -----------------------------------------------------------------------------

# Set to true to verify that inbound SMS requests genuinely originate from Vonage.
VALIDATE_VONAGE_SMS_SIGNATURE=false

# Required when VALIDATE_VONAGE_SMS_SIGNATURE=true
VONAGE_SIGNATURE_SECRET=

# Signature algorithm: md5hash | md5 | sha1 | sha256 | sha512 (default: md5hash)
VONAGE_SIGNATURE_ALGORITHM=md5hash

# -----------------------------------------------------------------------------
# Rate limiting — optional (sensible defaults provided)
# -----------------------------------------------------------------------------

# Outbound calls: max requests per window per destination number
OUTBOUND_CALL_RATE_LIMIT_MAX_REQUESTS=3
OUTBOUND_CALL_RATE_LIMIT_WINDOW_S=300

# Outbound SMS: max requests per window per destination number
OUTBOUND_SMS_RATE_LIMIT_MAX_REQUESTS=5
OUTBOUND_SMS_RATE_LIMIT_WINDOW_S=15

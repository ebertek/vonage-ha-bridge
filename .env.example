# =============================================================================
# vonage-ha-bridge — environment configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Port to listen on
PORT=3000

# Public base URL of this service (required for voice/outbound calls)
# Must be reachable by Vonage — use a reverse proxy or ngrok in development
# No trailing slash
BASE_URL=https://bridge.example.com

# Log level: debug | info | warning | error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Internal API
# -----------------------------------------------------------------------------

# Secret token required in the x-api-token header for all /api/* requests
# Use a strong random value, e.g.: openssl rand -hex 32
INTERNAL_API_TOKEN=

# -----------------------------------------------------------------------------
# Home Assistant
# -----------------------------------------------------------------------------

# Base URL of your Home Assistant instance — no trailing slash
HA_BASE_URL=http://homeassistant.local:8123

# Long-lived access token (generate in your HA profile page)
HA_LONG_LIVED_TOKEN=

# Webhook ID for inbound call events (must match your HA automation trigger)
HA_CALL_EVENT_WEBHOOK_ID=vonage_call_event

# Webhook ID for SMS delivery receipts (must match your HA automation trigger)
HA_SMS_DLR_WEBHOOK_ID=vonage_sms_dlr

# Assist agent ID to use for SMS conversations (leave empty to use the default)
HA_ASSIST_AGENT_ID=

# Language code passed to HA Assist
HA_LANGUAGE=en

# Timeout for HA Assist requests (seconds)
ASSIST_TIMEOUT_S=30

# -----------------------------------------------------------------------------
# Vonage
# -----------------------------------------------------------------------------

# Vonage API key and secret (from dashboard.vonage.com)
VONAGE_API_KEY=
VONAGE_API_SECRET=

# Your Vonage virtual number — digits only, with country code, no + prefix
# e.g. 46701234567
VONAGE_FROM_NUMBER=

# Vonage application ID (from the Applications section of the dashboard)
VONAGE_APPLICATION_ID=

# Path to the private key file downloaded when creating your Vonage application
VONAGE_PRIVATE_KEY_PATH=/app/private.key

# Timeout for outbound Vonage API requests (seconds)
OUTBOUND_TIMEOUT_S=10

# -----------------------------------------------------------------------------
# Vonage SMS signature validation (optional but recommended)
# -----------------------------------------------------------------------------

# Set to true to verify that inbound SMS requests are genuinely from Vonage
VALIDATE_VONAGE_SMS_SIGNATURE=false

# Required if VALIDATE_VONAGE_SMS_SIGNATURE=true
VONAGE_SIGNATURE_SECRET=

# Signature algorithm: md5hash | md5 | sha1 | sha256 | sha512
VONAGE_SIGNATURE_ALGORITHM=md5hash

# -----------------------------------------------------------------------------
# Call forwarding (at least one is required to forward inbound calls)
# -----------------------------------------------------------------------------

# SIP URI to forward inbound calls to (takes priority over phone number if both are set)
FORWARD_SIP_URI=

# Phone number to forward inbound calls to — digits only, with country code, no + prefix
FORWARD_PHONE_NUMBER=

# -----------------------------------------------------------------------------
# SMS
# -----------------------------------------------------------------------------

# Comma-separated list of phone numbers allowed to send SMS commands
# Leave empty to allow all senders
# e.g. 46701234567,46709876543
ALLOWED_SMS_SENDERS=

# Maximum SMS message length
SMS_MAX_LENGTH=1600

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------

# Outbound calls: max requests per window per destination number
OUTBOUND_CALL_RATE_LIMIT_MAX_REQUESTS=3
OUTBOUND_CALL_RATE_LIMIT_WINDOW_S=300

# Outbound SMS: max requests per window per destination number
OUTBOUND_SMS_RATE_LIMIT_MAX_REQUESTS=5
OUTBOUND_SMS_RATE_LIMIT_WINDOW_S=15

# -----------------------------------------------------------------------------
# Voice (TTS defaults)
# -----------------------------------------------------------------------------

# Default TTS language for outbound calls (Vonage voice)
DEFAULT_VOICE_LANGUAGE=en-US

# Default voice style (0 = default, varies by voice)
DEFAULT_VOICE_STYLE=0
